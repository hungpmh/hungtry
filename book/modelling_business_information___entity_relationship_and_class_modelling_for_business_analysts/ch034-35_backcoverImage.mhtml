@charset "utf-8";

.annotator-hl { background: rgba(255, 255, 10, 0.3); }

.annotator-hl-temporary { background: rgba(0, 124, 255, 0.3); }

.annotator-wrapper { position: relative; }

.annotator-adder, .annotator-outer, .annotator-notice { z-index: 1020; }

.annotator-filter { z-index: 1010; }

.annotator-hide { display: none; visibility: hidden; }

.annotator-adder { margin-top: -48px; margin-left: -24px; width: 48px; heig=
ht: 48px; background-position: left top; }

.annotator-adder:hover { background-position: center top; }

.annotator-adder:active { background-position: right center; }

.annotator-invert-x .annotator-widget { left: auto; right: -18px; }

.annotator-invert-y .annotator-widget { bottom: auto; top: 8px; }

.annotator-widget strong { font-weight: bold; }

.annotator-widget .annotator-listing, .annotator-widget .annotator-item { p=
adding: 0px; margin: 0px; list-style: none; }

.annotator-widget::after { content: ""; display: block; width: 18px; height=
: 10px; background-position: 0px 0px; position: absolute; bottom: -10px; le=
ft: 8px; }

.annotator-invert-x .annotator-widget::after { left: auto; right: 8px; }

.annotator-invert-y .annotator-widget::after { background-position: 0px -15=
px; bottom: auto; top: -9px; }

.annotator-viewer .annotator-item { border-top: 2px solid rgba(122, 122, 12=
2, 0.2); }

.annotator-widget .annotator-item:first-child { border-top: none; }

.annotator-viewer div { padding: 6px; }

.annotator-viewer .annotator-item ol, .annotator-viewer .annotator-item ul =
{ padding: 4px 16px; }

.annotator-hide.annotator-viewer .annotator-controls { position: relative; =
top: 5px; right: 5px; padding-left: 5px; opacity: 0; transition: opacity 0.=
2s ease-in 0s; float: right; }

.annotator-viewer li:hover .annotator-controls, .annotator-viewer li .annot=
ator-controls.annotator-visible { opacity: 1; }

.annotator-viewer .annotator-controls button:active, .annotator-viewer .ann=
otator-controls a:active { opacity: 1; }

.annotator-viewer .annotator-controls button[disabled] { display: none; }

.annotator-viewer .annotator-controls .annotator-edit { background-position=
: 0px -60px; }

.annotator-viewer .annotator-controls .annotator-delete { background-positi=
on: 0px -75px; }

.annotator-viewer .annotator-controls .annotator-link { background-position=
: 0px -270px; }

.annotator-editor .annotator-item { position: relative; }

.annotator-editor .annotator-item label { top: 0px; display: inline; font-s=
